generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
  DELAYED
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
  CRITICAL_DELAY
}

enum ActivityType {
  TASK_DEPENDENT
  RESOURCE_DEPENDENT
  START_MILESTONE
  FINISH_MILESTONE
  LEVEL_OF_EFFORT
}

enum RelationshipType {
  FS
  SS
  FF
  SF
}

enum ResourceType {
  LABOR
  EQUIPMENT
  MATERIAL
  SUBCONTRACTOR
}

model Project {
  id             String           @id @default(cuid())
  projectId      String           @unique
  projectName    String
  client         String
  contractor     String
  contractAmount Decimal          @db.Decimal(14, 2)
  startDate      DateTime
  finishDate     DateTime
  status         ProjectStatus    @default(PLANNED)
  wbs            Wbs[]
  activities     Activity[]
  calendars      Calendar[]
  baselines      Baseline[]
  reports        Report[]
  delayLogs      DelayLog[]
  progress       ProgressUpdate[]
  costCodes      CostCode[]
  boqItems       BoqItem[]
  procurement    ProcurementPackage[]
  locations      Location[]
  constraints    ConstraintLog[]
  lookaheadPlans LookaheadPlan[]
  risks          Risk[]
  documents      ProjectDocument[]
  approvals      ApprovalWorkflow[]
  auditLogs      AuditLog[]
  weatherLogs    WeatherLog[]
  changeOrders   ChangeOrder[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, startDate])
  @@index([client])
}

model Wbs {
  id          String     @id @default(cuid())
  projectId   String
  parentId    String?
  code        String
  name        String
  progressPct Decimal    @default(0) @db.Decimal(5, 2)
  duration    Int        @default(0)
  budgetCost  Decimal    @default(0) @db.Decimal(14, 2)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Wbs?       @relation("WbsTree", fields: [parentId], references: [id])
  children    Wbs[]      @relation("WbsTree")
  activities  Activity[]

  @@unique([projectId, code])
  @@index([projectId, parentId])
}

model Activity {
  id                String             @id @default(cuid())
  projectId         String
  wbsId             String
  calendarId        String?
  activityId        String
  activityName      String
  activityType      ActivityType       @default(TASK_DEPENDENT)
  duration          Int
  remainingDuration Int                @default(0)
  percentComplete   Decimal            @default(0) @db.Decimal(5, 2)
  startDate         DateTime
  finishDate        DateTime
  actualStart       DateTime?
  actualFinish      DateTime?
  earlyStart        DateTime?
  earlyFinish       DateTime?
  lateStart         DateTime?
  lateFinish        DateTime?
  totalFloat        Int                @default(0)
  freeFloat         Int                @default(0)
  isCritical        Boolean            @default(false)
  status            ActivityStatus     @default(NOT_STARTED)
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbs               Wbs                @relation(fields: [wbsId], references: [id])
  calendar          Calendar?          @relation(fields: [calendarId], references: [id])
  predecessors      Relationship[]     @relation("Successor")
  successors        Relationship[]     @relation("Predecessor")
  resources         ActivityResource[]
  costs             Cost?
  baselineItems     BaselineActivity[]
  progressUpdates   ProgressUpdate[]
  delayLogs         DelayLog[]
  quantityProgress  QuantityProgress[]
  procurement       ProcurementPackage[]
  constraints       ConstraintLog[]
  risks             Risk[]
  documents         ProjectDocument[]
  inspections       InspectionRequest[]

  @@unique([projectId, activityId])
  @@index([projectId, status])
  @@index([projectId, isCritical])
  @@index([startDate, finishDate])
}

model Relationship {
  id            String           @id @default(cuid())
  predecessorId String
  successorId   String
  type          RelationshipType @default(FS)
  lagDays       Int              @default(0)
  predecessor   Activity         @relation("Predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     Activity         @relation("Successor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId, type])
  @@index([successorId])
}

model Calendar {
  id          String     @id @default(cuid())
  projectId   String?
  name        String
  calendarType String
  workingDays Json
  holidays    Json
  overtime    Json?
  shifts      Json?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities  Activity[]

  @@index([projectId, calendarType])
}

model Resource {
  id          String             @id @default(cuid())
  resourceId  String             @unique
  name        String
  type        ResourceType
  unitCost    Decimal            @db.Decimal(12, 2)
  availability Decimal           @db.Decimal(10, 2)
  assignments ActivityResource[]

  @@index([type])
}

model ActivityResource {
  id          String   @id @default(cuid())
  activityId  String
  resourceId  String
  quantity    Decimal  @db.Decimal(12, 2)
  unitCost    Decimal  @db.Decimal(12, 2)
  totalCost   Decimal  @db.Decimal(14, 2)
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  resource    Resource @relation(fields: [resourceId], references: [id])

  @@unique([activityId, resourceId])
  @@index([resourceId])
}

model Cost {
  id            String   @id @default(cuid())
  activityId    String   @unique
  budgetCost    Decimal  @default(0) @db.Decimal(14, 2)
  actualCost    Decimal  @default(0) @db.Decimal(14, 2)
  remainingCost Decimal  @default(0) @db.Decimal(14, 2)
  forecastCost  Decimal  @default(0) @db.Decimal(14, 2)
  costVariance  Decimal  @default(0) @db.Decimal(14, 2)
  plannedValue  Decimal  @default(0) @db.Decimal(14, 2)
  earnedValue   Decimal  @default(0) @db.Decimal(14, 2)
  activity      Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Baseline {
  id          String             @id @default(cuid())
  projectId   String
  name        String
  savedAt     DateTime           @default(now())
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities  BaselineActivity[]

  @@index([projectId, savedAt])
}

model BaselineActivity {
  id             String   @id @default(cuid())
  baselineId     String
  activityId     String
  baselineStart  DateTime
  baselineFinish DateTime
  currentStart   DateTime
  currentFinish  DateTime
  varianceDays   Int
  baseline       Baseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  activity       Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([baselineId, activityId])
}

model ProgressUpdate {
  id                 String   @id @default(cuid())
  projectId          String
  activityId         String
  dataDate           DateTime
  percentComplete    Decimal  @db.Decimal(5, 2)
  dailyAccomplishment String
  actualCost         Decimal  @default(0) @db.Decimal(14, 2)
  productivity       Decimal? @db.Decimal(10, 2)
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity           Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([projectId, dataDate])
  @@index([activityId, dataDate])
}

model DelayLog {
  id          String   @id @default(cuid())
  projectId   String
  activityId  String
  delayType   String
  severity    String
  impactDays  Int
  description String
  detectedAt  DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([projectId, severity])
  @@index([activityId])
}

model Report {
  id          String   @id @default(cuid())
  projectId   String
  reportType  String
  format      String
  title       String
  generatedBy String
  generatedAt DateTime @default(now())
  payload     Json
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, reportType])
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String
  roles     UserRole[]
  createdAt DateTime @default(now())
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  permissions Json
  users       UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}


model CostCode {
  id          String    @id @default(cuid())
  projectId   String
  code        String
  description String
  discipline  String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  boqItems    BoqItem[]

  @@unique([projectId, code])
  @@index([projectId, discipline])
}

model BoqItem {
  id             String             @id @default(cuid())
  projectId      String
  costCodeId     String
  itemCode       String
  description    String
  unitOfMeasure  String
  budgetQuantity Decimal            @db.Decimal(14, 3)
  unitRate       Decimal            @db.Decimal(14, 2)
  budgetAmount   Decimal            @db.Decimal(14, 2)
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCode       CostCode           @relation(fields: [costCodeId], references: [id])
  progress       QuantityProgress[]

  @@unique([projectId, itemCode])
  @@index([costCodeId])
}

model QuantityProgress {
  id                  String   @id @default(cuid())
  activityId          String
  boqItemId           String
  dataDate            DateTime
  installedQuantity   Decimal  @db.Decimal(14, 3)
  cumulativeQuantity  Decimal  @db.Decimal(14, 3)
  plannedProductivity Decimal? @db.Decimal(12, 3)
  actualProductivity  Decimal? @db.Decimal(12, 3)
  activity            Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  boqItem             BoqItem  @relation(fields: [boqItemId], references: [id])

  @@index([activityId, dataDate])
  @@index([boqItemId])
}

model ProcurementPackage {
  id                 String    @id @default(cuid())
  projectId          String
  activityId         String?
  packageNumber      String
  description        String
  supplier           String
  requiredOnSiteDate DateTime
  plannedDelivery    DateTime
  actualDelivery     DateTime?
  status             String
  delayImpactDays    Int       @default(0)
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity           Activity? @relation(fields: [activityId], references: [id])

  @@unique([projectId, packageNumber])
  @@index([projectId, status])
  @@index([activityId])
}

model Location {
  id        String   @id @default(cuid())
  projectId String
  parentId  String?
  code      String
  name      String
  type      String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Location? @relation("LocationTree", fields: [parentId], references: [id])
  children  Location[] @relation("LocationTree")

  @@unique([projectId, code])
  @@index([projectId, parentId])
}

model ConstraintLog {
  id          String    @id @default(cuid())
  projectId   String
  activityId  String?
  category    String
  owner       String
  dueDate     DateTime
  status      String
  resolution  String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity    Activity? @relation(fields: [activityId], references: [id])

  @@index([projectId, status])
  @@index([activityId])
}

model LookaheadPlan {
  id                String   @id @default(cuid())
  projectId         String
  weekStart         DateTime
  planWindowWeeks   Int      @default(6)
  plannedActivities Json
  percentPlanComplete Decimal @default(0) @db.Decimal(5, 2)
  varianceReasons   Json?
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, weekStart])
}

model ProjectDocument {
  id         String    @id @default(cuid())
  projectId  String
  activityId String?
  documentNo String
  type       String
  title      String
  status     String
  dueDate    DateTime?
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity   Activity? @relation(fields: [activityId], references: [id])

  @@unique([projectId, documentNo])
  @@index([activityId, type])
}

model InspectionRequest {
  id          String    @id @default(cuid())
  activityId  String
  requestNo   String
  inspectionDate DateTime
  status      String
  result      String?
  reworkNotes String?
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, requestNo])
  @@index([status])
}

model Risk {
  id          String    @id @default(cuid())
  projectId   String
  activityId  String?
  riskNo      String
  title       String
  probability Decimal   @db.Decimal(5, 2)
  impactDays  Int
  impactCost  Decimal   @db.Decimal(14, 2)
  owner       String
  mitigation  String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity    Activity? @relation(fields: [activityId], references: [id])

  @@unique([projectId, riskNo])
  @@index([projectId, probability])
}

model ApprovalWorkflow {
  id          String   @id @default(cuid())
  projectId   String
  itemType    String
  itemId      String
  status      String
  approver    String
  submittedAt DateTime @default(now())
  approvedAt  DateTime?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  projectId   String
  userId      String?
  entityType  String
  entityId    String
  action      String
  oldValue    Json?
  newValue    Json?
  reason      String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([entityType, entityId])
}

model WeatherLog {
  id          String   @id @default(cuid())
  projectId   String
  logDate     DateTime
  condition   String
  temperature Decimal? @db.Decimal(5, 2)
  lostHours   Decimal  @default(0) @db.Decimal(5, 2)
  notes       String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, logDate])
}

model ChangeOrder {
  id             String   @id @default(cuid())
  projectId      String
  changeOrderNo  String
  title          String
  status         String
  costImpact     Decimal  @default(0) @db.Decimal(14, 2)
  scheduleImpact Int      @default(0)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, changeOrderNo])
  @@index([projectId, status])
}
